<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/logo_pages"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/logo_pages"
            android:adjustViewBounds="true">
        </ImageView>

        <View
            android:id="@+id/divider"
            android:layout_width="wrap_content"
            android:layout_height="3dp"
            android:background="@color/white">
        </View>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical">

        <com.getpet.components.PrimaryButton
            android:id="@+id/back_from_single_post_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="20dp"
            android:text="@string/activity_single_post_label_back"
            android:drawableStart="@drawable/ic_left_arrow"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_margin="0dp"
        android:background="@drawable/frame">

        <TextView
            android:id="@+id/pet_details_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:fontFamily="@font/titles_font_handlee"
            android:text="@string/activity_single_post_label_pet_details"
            android:textSize="35sp"
            android:textStyle="bold"
            android:layout_gravity="center">

        </TextView>

     <ImageView
         android:id="@+id/single_pet_image"
         android:layout_width="250dp"
         android:layout_height="150dp"
         android:scaleType="centerCrop"
         android:layout_gravity="center">

     </ImageView>

     <LinearLayout
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:orientation="vertical"
         android:layout_margin="5dp">

         <TextView
             android:id="@+id/activity_single_post_kind_label"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_margin="15dp"
             android:fontFamily="@font/text_font_raleway"
             app:drawableStartCompat="@drawable/ic_pet_leg"
             android:text="@string/activity_single_post_label_kind"
             android:textSize="20sp"
             android:textStyle="bold"
             android:drawablePadding="3dp">
         </TextView>

         <TextView
             android:id="@+id/activity_single_post_age_label"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:fontFamily="@font/text_font_raleway"
             android:layout_margin="15dp"
             app:drawableStartCompat="@drawable/ic_age"
             android:text="@string/activity_single_post_label_age"
             android:textSize="20sp"
             android:textStyle="bold"
             android:drawablePadding="1dp">
         </TextView>

         <TextView
             android:id="@+id/activity_single_post_about_label"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:fontFamily="@font/text_font_raleway"
             android:layout_margin="15dp"
             app:drawableStartCompat="@drawable/ic_add"
             android:text="@string/activity_single_post_label_about"
             android:textSize="20sp"
             android:textStyle="bold">
         </TextView>

         <TextView
             android:id="@+id/activity_single_post_phone_to_connect_label"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:fontFamily="@font/text_font_raleway"
             android:layout_margin="15dp"
             app:drawableStartCompat="@drawable/ic_phone"
             android:text="@string/activity_single_post_label_phone_to_connect"
             android:textSize="20sp"
             android:textStyle="bold"
             android:drawablePadding="2dp">
         </TextView>

         <TextView
             android:id="@+id/activity_single_post_location_label"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:fontFamily="@font/text_font_raleway"
             android:layout_margin="15dp"
             app:drawableStartCompat="@drawable/ic_location"
             android:text="@string/activity_single_post_label_location"
             android:textSize="20sp"
             android:textStyle="bold"
             android:drawablePadding="2dp">
         </TextView>

         <TextView
             android:id="@+id/activity_single_post_owner_name_label"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:fontFamily="@font/text_font_raleway"
             android:layout_margin="15dp"
             app:drawableStartCompat="@drawable/ic_person"
             android:text="@string/activity_single_post_label_owner_name"
             android:textSize="20sp"
             android:textStyle="bold"
             android:drawablePadding="1dp">
         </TextView>

     </LinearLayout>

    </LinearLayout>

</LinearLayout>